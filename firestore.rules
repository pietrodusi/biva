rules_version = '2';

// Each signed-in user can read and write only their own data silo under
// users/{uid}. No cross-account access. Paste this into the Firebase console
// (Firestore Database -> Rules) or deploy with the Firebase CLI.
//
// Optional hardening: to stop any other Google account from creating a silo,
// replace the uid check with an allowlist, e.g.
//   allow read, write: if request.auth != null
//     && request.auth.uid == uid
//     && request.auth.token.email == 'you@example.com';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}

# Firebase web app config — Firebase console → Project settings → Your apps →
# SDK setup and configuration. These values are embedded in the client bundle
# and are NOT secrets for a web app: access is enforced by Firebase Auth and
# Firestore security rules, not by hiding them.
#
# Local dev:  copy this file to `.env.local` and fill in the values.
# Production: set the same names as GitHub Actions repository secrets
#             (Settings → Secrets and variables → Actions); the deploy workflow
#             injects them into the build.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
